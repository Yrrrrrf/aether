{
  "name": "@yrrrrrf/aether",
  "version": "0.2.0",
  "description": "A type-safe edge client and schema generator for pREST, PostgREST and Supabase.",
  "license": "MIT",
  "exports": {
    ".": "./src/runtime/mod.ts",
    "./generator": "./src/oracle/mod.ts"
  },
  "tasks": {
    "dev": "deno test --watch",
    "generate": "deno run --allow-net --allow-read --allow-write --allow-env src/oracle/cli.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env tests/"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/dotenv": "jsr:@std/dotenv@0.225.2",
    "postgres": "jsr:@db/postgres@^0.19.3",
    "up-fetch": "npm:up-fetch@^2.5.1"
  },
  "fmt": {
    "singleQuote": false,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}